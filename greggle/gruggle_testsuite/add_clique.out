digraph G {
    graph [nodesep=0.35, ranksep=0.5, splines=spline];
    node [color="#4a6fa5", fillcolor="#e6f2ff", fontname=Helvetica, fontsize=10, shape=box, style="rounded,filled"];
    edge [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_1 [color="#4a6fa5", fillcolor="#e6f2ff", fontname=Helvetica, fontsize=10, shape=box, style="rounded,filled"];
    q_2 [color="#4a6fa5", fillcolor="#e6f2ff", fontname=Helvetica, fontsize=10, shape=box, style="rounded,filled"];
    q_3 [color="#4a6fa5", fillcolor="#e6f2ff", fontname=Helvetica, fontsize=10, shape=box, style="rounded,filled"];
    q_1 -> q_2 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_1 -> q_3 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_2 -> q_1 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_2 -> q_3 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_3 -> q_1 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
    q_3 -> q_2 [arrowsize=0.8, color="#4a6fa5", penwidth=1.2];
}
