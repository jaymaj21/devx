digraph G {
    rankdir=LR;
    node [shape=circle];

    n1 -> n3  [label="a"];
    n1 -> n2  [label="b,c"];

    n3 -> n2  [label="a,b"];

    n2 -> n8  [label="a"];
    n2 -> n6  [label="b,c"];
    n2 -> n4  [label="a"];

    n8 -> n7  [label="b"];
    n7 -> n6  [label="a"];

    n6 -> n5  [label="b"];
    n6 -> n10 [label="b"];

    n10 -> n5 [label="a"];
    n10 -> n9 [label="a"];

    n5 -> n4  [label="a"];

    n4 -> n9;   // unlabeled edge
}
