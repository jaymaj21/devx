<h1>Edit Order item</h1>

<%= form_with model: @order_item, local: true do |f| %>
  <div class="field">
    <%= f.label :id, "Id" %>
    <%= f.text_field :id %>
  </div>

  <div class="field">
    <%= f.label :order_id, "Order id" %>
    <%= f.text_field :order_id %>
  </div>

  <div class="field">
    <%= f.label :product_id, "Product id" %>
    <%= f.text_field :product_id %>
  </div>

  <div class="field">
    <%= f.label :quantity, "Quantity" %>
    <%= f.text_field :quantity %>
  </div>

  <div class="field">
    <%= f.label :unit_price, "Unit price" %>
    <%= f.text_field :unit_price %>
  </div>

  <div class="field">
    <%= f.label :line_total, "Line total" %>
    <%= f.text_field :line_total %>
  </div>

  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>

<%= link_to 'Show', @order_item %> |
<%= link_to 'Back', order_items_path %>
