<h1>User account</h1>
<p>
  <strong>Id:</strong>
  <%= @user_account.id %>
</p>

<p>
  <strong>Username:</strong>
  <%= @user_account.username %>
</p>

<p>
  <strong>Hashed password:</strong>
  <%= @user_account.hashed_password %>
</p>

<p>
  <strong>Email:</strong>
  <%= @user_account.email %>
</p>

<p>
  <strong>Role:</strong>
  <%= @user_account.role %>
</p>

<p>
  <strong>Active:</strong>
  <%= @user_account.active %>
