<h1>Edit Address</h1>

<%= form_with model: @address, local: true do |f| %>
  <div class="field">
    <%= f.label :id, "Id" %>
    <%= f.text_field :id %>
  </div>

  <div class="field">
    <%= f.label :person_id, "Person id" %>
    <%= f.text_field :person_id %>
  </div>

  <div class="field">
    <%= f.label :street, "Street" %>
    <%= f.text_field :street %>
  </div>

  <div class="field">
    <%= f.label :city, "City" %>
    <%= f.text_field :city %>
  </div>

  <div class="field">
    <%= f.label :state, "State" %>
    <%= f.text_field :state %>
  </div>

  <div class="field">
    <%= f.label :zip_code, "Zip code" %>
    <%= f.text_field :zip_code %>
  </div>

  <div class="field">
    <%= f.label :country, "Country" %>
    <%= f.text_field :country %>
  </div>

  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>

<%= link_to 'Show', @address %> |
<%= link_to 'Back', addresss_path %>
