<h1>Edit Invoice</h1>

<%= form_with model: @invoice, local: true do |f| %>
  <div class="field">
    <%= f.label :id, "Id" %>
    <%= f.text_field :id %>
  </div>

  <div class="field">
    <%= f.label :order_id, "Order id" %>
    <%= f.text_field :order_id %>
  </div>

  <div class="field">
    <%= f.label :invoice_number, "Invoice number" %>
    <%= f.text_field :invoice_number %>
  </div>

  <div class="field">
    <%= f.label :issued_at, "Issued at" %>
    <%= f.text_field :issued_at %>
  </div>

  <div class="field">
    <%= f.label :due_at, "Due at" %>
    <%= f.text_field :due_at %>
  </div>

  <div class="field">
    <%= f.label :total, "Total" %>
    <%= f.text_field :total %>
  </div>

  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>

<%= link_to 'Show', @invoice %> |
<%= link_to 'Back', invoices_path %>
