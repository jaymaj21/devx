digraph "instrument-lifecycle-small" {
  graph [rankdir="TB", labelloc="t", label="instrument-lifecycle-small\nreachable 5/400 states\n8 visible transitions\n1 deadlocks\n0 invariant-bad states\nsee legend for actions and properties\nnode labels begin with a short state id", fontname="Helvetica", overlap="false", splines="true", nodesep="0.2", ranksep="0.75"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.12,0.08", color="#355070", fillcolor="#f8f9fb"];
  edge [fontname="Helvetica", fontsize=9, color="#6d597a"];
  "__start__" [shape=point, width=0.2, color="#2a9d8f", fillcolor="#2a9d8f", label=""];
  "n_" [label="s0\nmaster: life=\"enriching\", trad.stat=\"not_trading\", refd.vers=1\nvenue1: life=\"enriching\", trad.stat=\"not_trading\", refd.vers=1\ninit", tooltip="[[\"master_lifecycle\",\"enriching\"],[\"master_trading_status\",\"not_trading\"],[\"master_refdata_version\",1],[\"venue1_lifecycle\",\"enriching\"],[\"venue1_trading_status\",\"not_trading\"],[\"venue1_refdata_version\",1]]", fillcolor="#d8f3dc", color="#2d6a4f", penwidth=2];
  "n_" [label="s1\nmaster: life=\"ready\", trad.stat=\"not_trading\", refd.vers=1\nvenue1: life=\"ready\", trad.stat=\"not_trading\", refd.vers=1", tooltip="[[\"master_lifecycle\",\"ready\"],[\"master_trading_status\",\"not_trading\"],[\"master_refdata_version\",1],[\"venue1_lifecycle\",\"ready\"],[\"venue1_trading_status\",\"not_trading\"],[\"venue1_refdata_version\",1]]"];
  "n_" [label="s2\nmaster: life=\"active\", trad.stat=\"trading\", refd.vers=1\nvenue1: life=\"active\", trad.stat=\"trading\", refd.vers=1", tooltip="[[\"master_lifecycle\",\"active\"],[\"master_trading_status\",\"trading\"],[\"master_refdata_version\",1],[\"venue1_lifecycle\",\"active\"],[\"venue1_trading_status\",\"trading\"],[\"venue1_refdata_version\",1]]"];
  "n_" [label="s3\nmaster: life=\"halted\", trad.stat=\"paused\", refd.vers=1\nvenue1: life=\"halted\", trad.stat=\"paused\", refd.vers=1", tooltip="[[\"master_lifecycle\",\"halted\"],[\"master_trading_status\",\"paused\"],[\"master_refdata_version\",1],[\"venue1_lifecycle\",\"halted\"],[\"venue1_trading_status\",\"paused\"],[\"venue1_refdata_version\",1]]"];
  "n_" [label="s4\nmaster: life=\"disabled\", trad.stat=\"disabled\", refd.vers=1\nvenue1: life=\"disabled\", trad.stat=\"disabled\", refd.vers=1\ndeadlock", tooltip="[[\"master_lifecycle\",\"disabled\"],[\"master_trading_status\",\"disabled\"],[\"master_refdata_version\",1],[\"venue1_lifecycle\",\"disabled\"],[\"venue1_trading_status\",\"disabled\"],[\"venue1_refdata_version\",1]]", fillcolor="#fff3bf", color="#e67700", penwidth=2];
  "__start__" -> "n_" [color="#2a9d8f", penwidth=2];
  "n_" -> "n_" [label="enrich"];
  "n_" -> "n_" [label="disable"];
  "n_" -> "n_" [label="start"];
  "n_" -> "n_" [label="disable"];
  "n_" -> "n_" [label="pause"];
  "n_" -> "n_" [label="disable"];
  "n_" -> "n_" [label="resume"];
  "n_" -> "n_" [label="disable"];
}
